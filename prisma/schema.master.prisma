// Master Database Schema - Tenant Management
// This schema is for the central database that manages all tenant databases

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/master-client"
}

datasource db {
  provider = "mysql"
  url      = env("MASTER_DATABASE_URL")
}

// ============================================
// TENANT MANAGEMENT
// ============================================
model Tenant {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(100)
  subdomain    String    @unique @db.VarChar(50)
  dbName       String    @unique @map("db_name") @db.VarChar(50)
  dbHost       String    @default("localhost") @map("db_host") @db.VarChar(100)
  dbPort       Int       @default(3306) @map("db_port")
  status       String    @default("active") @db.VarChar(20)
  plan         String    @default("basic") @db.VarChar(20)
  contactName  String?   @map("contact_name") @db.VarChar(100)
  contactEmail String?   @map("contact_email") @db.VarChar(100)
  contactPhone String?   @map("contact_phone") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("tenants")
}

// ============================================
// SUPER ADMIN USERS
// ============================================
model SuperAdmin {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @map("full_name") @db.VarChar(100)
  status       String    @default("active") @db.VarChar(20)
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("super_admins")
}

// ============================================
// SYSTEM SETTINGS
// ============================================
model SystemSetting {
  id           String   @id @default(uuid())
  settingKey   String   @unique @map("setting_key") @db.VarChar(100)
  settingValue String?  @map("setting_value") @db.Text
  description  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

